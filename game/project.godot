; Engine configuration file.
; Godot 4.x - see docs/BUILD.md. Open this folder as the project root.

config_version=5

[application]

config/name="claude_rts"
config/description="SC2-inspired deterministic RTS - playable foundation skirmish."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[rendering]

environment/defaults/default_clear_color=Color(0.012, 0.02, 0.035, 1)
renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
textures/vram_compression/import_s3tc_bptc=true
