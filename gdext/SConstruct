#!/usr/bin/env python
# Build the claude_rts GDExtension ("sim_rts") against godot-cpp.
#
#   scons platform=macos   arch=universal target=template_debug|template_release
#   scons platform=windows arch=x86_64    target=template_debug|template_release
#
# Sim backend (default = B's real deterministic sim):
#   (default)        links sim/src + the EnTT submodule (gdext/entt)
#   use_real_sim=no  builds the bundled mock instead (mock_sim.cpp; no EnTT needed) —
#                    handy for isolated view dev. The mock self-disables when the real
#                    sim is built (SIM_RTS_USE_REAL_SIM).
import os

env = SConscript("godot-cpp/SConstruct")

env.Append(CPPPATH=["src/", os.path.join("..", "sim", "include")])

sources = Glob("src/*.cpp")  # includes mock_sim.cpp (self-disables under SIM_RTS_USE_REAL_SIM)

# Default to B's real deterministic sim; pass use_real_sim=no for the mock.
if ARGUMENTS.get("use_real_sim", "yes") == "yes":
    env.Append(CPPDEFINES=["SIM_RTS_USE_REAL_SIM"])
    env.Append(CPPPATH=[os.path.join("entt", "single_include")])  # EnTT (header-only, pinned submodule)
    sources += Glob(os.path.join("..", "sim", "src", "*.cpp"))

project_bin = os.path.join("..", "game", "bin")

if env["platform"] == "macos":
    target = "{}/libsim_rts.{}.{}.framework/libsim_rts.{}.{}".format(
        project_bin, env["platform"], env["target"], env["platform"], env["target"]
    )
else:
    target = "{}/libsim_rts{}{}".format(project_bin, env["suffix"], env["SHLIBSUFFIX"])

library = env.SharedLibrary(target, source=sources)

Default(library)
